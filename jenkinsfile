pipeline {
    agent any

    environment {
        AWS_REGION = "ap-south-1"

    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/ajitkumar-tech/terraform.git'
            }
        }

        stage('AWS Configure') {
            steps {
                withCredentials([[$class: 'AmazonWebServicesCredentialsBinding', credentialsId: 'my-crd']]) {
                    sh '''
                        aws sts get-caller-identity
                        aws configure set region $AWS_REGION
                    '''
                }
            }
        }

        stage('Terraform Init') {
            steps {
                sh '''
                    terraform init
                '''
            }
        }

        
        stage('Terraform Plan') {
            steps {
                sh '''
                    terraform plan 
                '''
            }
        }

        stage('Terraform Apply') {
            steps {
                
                sh '''
                    terraform apply -auto-approve 
                '''
            }
        }
    }
}    
    
